System cargoservice
// Container requests
Request loadRequest : loadRequest(X)
Reply retryLater : retryLater(RetryMessage) for loadRequest
Reply rejected : rejected(RejectedMessage) for loadRequest
Reply accepted : accepted(SlotID) for loadRequest

// Container marking
Request markContainer : markContainer(ID)
Reply markDone : markDone(msg) for markContainer

// Sonar events
Event serviceWorking : serviceWorking(X)
Event outOfService : outOfService(X)
Event iOPortDeposited : iOPortDeposited(X) //cannot be dispatch because it would be stored in the message queue
Dispatch sonardata : sonardata(Distance)
Dispatch blinkLed : blinkLed(Blink)

/* 
 * ------------------------------------------------
 * Handled by robotsmart
 * ------------------------------------------------
*/
Request moverobot : moverobot(TARGETX, TARGETY,STEPTIME)
Reply moverobotdone  :  moverobotok(ARG) for moverobot
Reply moverobotfailed:  moverobotfailed(PLANDONE, PLANTODO) for moverobot

Dispatch setplanbuildelay : value(V)
 
Dispatch move : move(M) "MOVE = l|r|a|d|h mosse aril sincrone ok"
Dispatch setrobotstate: setpos(X,Y,D) "set robot position to (X,Y) direction D=up|down|left|right" 

Request setdirection : dir( D ) "set robot direction to D=up|down|left|right" 
Reply setdirectiondone : pos(PX,PY) for setdirection

Context ctxcargoservice ip [ host="localhost" port=5000 ]
Context ctxrobotsmart ip [host="robotsmart26" port=8020] 

ExternalQActor robotsmart context ctxrobotsmart

QActor cargoservice context ctxcargoservice {
	[#val TimeoutMillis = 30000L
	  var IOPortOccupied = false
	  var IsEngaged = false
	  var hold = model.Hold()
	  val StepTime = 345
	  var lastOccupiedSlot = hold.getSlots().get(0)
	  
	  fun allSlotsOccupied(): Boolean {
	      return hold.getSlots().all({ it.second.isOccupied() })
	  }
	  #]
	
	State s0 initial {
		forward robotsmart -m setrobotstate : setpos(0, 0, down)
		forward robotsmart -m setplanbuildelay : value(0)
		delay 500
	}
	Goto disengaged
	
    State disengaged {
    	[#IsEngaged = false#]
    	forward sonarwrapper -m blinkLed : blinkLed(False)
    	
    	println("$name | Disengaged") color green
    }
    Transition t0
    	whenRequest loadRequest -> handleRequest

	State handleRequest {
		[#var canEngage = true#]
		if [# IOPortOccupied #] {
			println("$name | Reply retry later") color blue
			replyTo loadRequest with retryLater : retryLater(IOPortOccupied)
			[#canEngage = false#]
		}
		if [# allSlotsOccupied() #] {
			println("$name | Reply rejected") color blue
			replyTo loadRequest with rejected : rejected(AllSlotsFull)
			[#canEngage = false#]
		}
		
		if [#canEngage#] {
			[#IsEngaged = true
			
			val freeSlot = hold.getSlots().first({ !it.second.isOccupied() }).second;
			
		  	freeSlot.setOccupied(true);
		  	val SlotId = freeSlot.getID();#]
		  	
			replyTo loadRequest with accepted : accepted($SlotId)
		}
	}	
	Goto engaged if [#IsEngaged#] else disengaged
	
	State engaged {
        println("$name | Engaged") color green
        
        forward sonarwrapper -m blinkLed : blinkLed(True)
    }
    Transition t0
        whenTimeVar TimeoutMillis -> disengaged
        whenEvent iOPortDeposited -> moveRobotHomeToIoPort
   
   	State moveRobotHomeToIoPort {
   		request robotsmart -m moverobot : moverobot(4, 0, $StepTime)
        
   		println("$name | Move robot to ioport") color green
   	}
   	Transition t0
 		whenReply moverobotdone -> moveRobotIoPortToSlot5
 		whenReply moverobotfailed -> handleRobotError
   
   	State moveRobotIoPortToSlot5 {
   		println("$name | Move robot to slot 5") color green
   		request robotsmart -m moverobot : moverobot(2, 5, $StepTime)
   		
   		delay 3000
   	}
   	Transition t0
 		whenReply moverobotdone -> markContainer
 		whenReply moverobotfailed -> handleRobotError
 		
 	State markContainer {
 		delay 3000
 	}
 	Goto moveRobotSlot5ToReservedSlot
   
   	State moveRobotSlot5ToReservedSlot {
   		println("$name | Move robot to reserved slot") color green
   		request robotsmart -m moverobot : moverobot(4, 2, $StepTime)
   	}
   	Transition t0
 		whenReply moverobotdone -> moveRobotReservedSlotToHome
 		whenReply moverobotfailed -> handleRobotError
   
   	State moveRobotReservedSlotToHome {
   		println("$name | Move robot to home") color green
   		request robotsmart -m moverobot : moverobot(0, 0, $StepTime)
   	}
	Transition t0
		whenReply moverobotdone -> resetRobot
		whenReply moverobotfailed -> handleRobotError
		
	State resetRobot {
		request robotsmart -m setdirection : dir(Down)
	}
	Goto disengaged
   
   	State handleRobotError {
   	
   	}
   	Goto disengaged
}

QActor sonarwrapper context ctxcargoservice {
	[#val DFREE = 30
	  var isOutOfService = false#
	]
    State s0 initial {
    	connectToMqttBroker "tcp://mosquitto:1883"
		subscribe "sonar/data"
    }
    Transition t0
		whenMsg sonardata -> handleDistance

	State handleDistance {
		onMsg(sonardata : sonardata(Distance)) {
			[#val distance = "${payloadArg(0)}".toDouble()#]
			
			if [#!isOutOfService && distance > DFREE#] {
				[#isOutOfService = true#]
				println("$name | Out of service") color blue
				emit outOfService : outOfService(OutOfService)
			}	
			if [#isOutOfService && distance < DFREE#] {
				[#isOutOfService = false#]
				println("$name | Service working") color blue
				
				emit serviceWorking : serviceWorking(ServiceWorking)
			}
			if [#distance < DFREE / 2#] {
				println("$name | Container deposited") color blue

				emit iOPortDeposited : iOPortDeposited(DepositedToIOPort)
			}
		
		}
	}
	Transition t0
		whenMsg sonardata -> handleDistance
		whenMsg blinkLed -> handleBlinkLed
		
	State handleBlinkLed {
		println("$name | Forwarding blinkLed to sonar") color blue
		onMsg(blinkLed : blinkLed(Status)) {
			[# val msg = MsgUtil.buildDispatch(name, "blinkLed", "blinkLed(${payloadArg(0)})", "sonar")
	 		   println("Sending " + msg.toString())
	 		   mqtt.publish("sonar/led", msg.toString())#]
		}
	}
	Transition t0
		whenMsg sonardata -> handleDistance
		whenMsg blinkLed -> handleBlinkLed
}